# Local .terraform directory, generated by Terraform CLI
.terraform/

# State files (local backend only)
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files, often contain secrets
*.tfvars
*.tfvars.json

# Override and local change files
override.tf
*_override.tf*
override.tf.json
*_override.tf.json

# Terraform plan output (optional)
*.tfplan

# CLI configuration files
terraform.rc
.terraformrc

# Editor / IDE files
.vscode/
.idea/

# OS‑specific files
.DS_Store
Thumbs.db

# Ignore the last known IP file for scripts
/scripts/.last_known_ip

#Ansible
ansible/collections/
ansible/.vault_pass