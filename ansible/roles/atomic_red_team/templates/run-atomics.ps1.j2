# {{ ansible_managed }}
# Generated by the atomic_red_team role — do not edit by hand.
$ErrorActionPreference = 'Continue'
$logPath = "{{ atomic_red_team_install_dir }}\scheduled-run.log"

Import-Module "{{ atomic_red_team_install_dir }}\invoke-atomicredteam\Invoke-AtomicRedTeam.psd1" -Force

"=== Run started: $(Get-Date -Format o) ===" | Out-File -FilePath $logPath -Append

{% for item in atomic_red_team_techniques %}
try {
    Invoke-AtomicTest {{ item.technique }} -TestNumbers "{{ item.test_numbers }}" `
        -PathToAtomicsFolder "{{ atomic_red_team_install_dir }}\atomics" 2>&1 |
        Out-File -FilePath $logPath -Append
} catch {
    "ERROR running {{ item.technique }}: $($_.Exception.Message)" | Out-File -FilePath $logPath -Append
}
{% endfor %}

"=== Run finished: $(Get-Date -Format o) ===" | Out-File -FilePath $logPath -Append